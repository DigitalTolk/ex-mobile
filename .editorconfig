root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,jsonc,css,html,xml,plist,yml,yaml,md,rb}]
indent_style = space
indent_size = 2

[*.{swift,java,kt,kts,gradle}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
