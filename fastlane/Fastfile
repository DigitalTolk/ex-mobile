default_platform(:ios)

platform :ios do
  desc "Upload a PR build to TestFlight"
  lane :testflight_pr do
    setup_ci
    install_ci_signing
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "ex-mobile.ipa"
    )
    upload_to_testflight(
      api_key: app_store_api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload a tagged build to App Store Connect"
  lane :app_store_release do
    setup_ci
    install_ci_signing
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "ex-mobile.ipa"
    )
    upload_to_app_store(
      api_key: app_store_api_key,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end

  private_lane :app_store_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"),
      is_key_content_base64: true,
      duration: 1200
    )
  end

  private_lane :install_ci_signing do
    keychain_name = "build.keychain"
    create_keychain(
      name: keychain_name,
      password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", "ci-keychain-password"),
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    certificate_path = "build/ios/certificate.p12"
    profile_path = "build/ios/profile.mobileprovision"
    sh("mkdir -p build/ios")
    File.binwrite(certificate_path, Base64.decode64(ENV.fetch("IOS_CERTIFICATE_P12_BASE64")))
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))

    import_certificate(
      certificate_path: certificate_path,
      certificate_password: ENV.fetch("IOS_CERTIFICATE_PASSWORD"),
      keychain_name: keychain_name,
      keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", "ci-keychain-password")
    )
    install_provisioning_profile(path: profile_path)
  end
end
